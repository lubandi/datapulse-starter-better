# --- Core Application ---
DEBUG=True
SECRET_KEY=local-django-insecure-key-for-development
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database ---
# Replace with actual PostgreSQL URL if running locally instead of docker
DATABASE_URL=postgres://postgres:postgres@db:5432/datapulse

# --- Production Settings (Only used if DJANGO_SETTINGS_MODULE is prod) ---
# ALLOWED_HOSTS=localhost,127.0.0.1
# CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Gunicorn Tuning ---
GUNICORN_WORKERS=3
GUNICORN_THREADS=4
GUNICORN_LOG_LEVEL=info
