# --- Django General ---
SECRET_KEY=change-me-in-production
# DJANGO_SETTINGS_MODULE=datapulse.settings.dev

# --- Database ---
# For Docker: postgresql://datapulse:datapulse@db:5432/datapulse
# For Local Postgres: postgresql://<user>:<password>@localhost:5432/<dbname>
DATABASE_URL=postgresql://datapulse:datapulse@localhost:5432/datapulse

# --- Redis (Celery) ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Email ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=datapulse@amalitech.com
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
